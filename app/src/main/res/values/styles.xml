<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:fontFamily">@font/chalkduster</item>
        <item name="fontFamily">@font/chalkduster</item>
        <item name="android:textViewStyle">@style/GameTextView</item>
    </style>

    <style name="NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:fontFamily">@font/chalkduster</item>
        <item name="fontFamily">@font/chalkduster</item>
        <item name="android:textViewStyle">@style/GameTextView</item>
    </style>

    <style name="HalfScreen" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@drawable/background</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:fontFamily">@font/chalkduster</item>
        <item name="fontFamily">@font/chalkduster</item>
        <item name="android:textViewStyle">@style/GameTextView</item>
    </style>

    <!-- Button Styles -->
    <style name="GameButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/button_bg</item>
        <item name="android:fontFamily">@font/chalkduster</item>
        <item name="fontFamily">@font/chalkduster</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="GameButton.MainMenu">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minWidth">200dp</item>
    </style>

    <style name="GameButton.Dialog">
        <item name="android:textSize">16sp</item>
        <item name="android:minWidth">140dp</item>
    </style>

    <style name="GameButton.Back">
        <item name="android:textSize">18sp</item>
        <item name="android:minWidth">120dp</item>
    </style>

    <style name="GameButton.Option">
        <item name="android:textSize">18sp</item>
        <item name="android:minWidth">160dp</item>
    </style>

    <!-- TextView Style -->
    <style name="GameTextView" parent="android:Widget.TextView">
        <item name="android:fontFamily">@font/chalkduster</item>
        <item name="fontFamily">@font/chalkduster</item>
    </style>

</resources>
