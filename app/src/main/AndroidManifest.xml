<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="cn.com.example.wendi.rollingball" >

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.Holo.Light.NoActionBar.Fullscreen" >
        <activity
            android:name=".MainMenu"
            android:label="@string/app_name" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".SurfaceViewActivity"
            android:label="@string/title_activity_surface_view" >
        </activity>
        <activity
            android:name=".HowTo"
            android:label="@string/title_activity_how_to" >
        </activity>
        <activity
            android:name=".Option"
            android:label="@string/title_activity_option" >
        </activity>
        <activity
            android:name=".FinalScore"
            android:label="@string/title_activity_final_score"
            android:theme="@style/HalfScreen">
        </activity>
        <activity
            android:name=".Pause"
            android:label="@string/title_activity_pause"
            android:theme="@style/HalfScreen">
        </activity>
    </application>
    <uses-permission android:name="android.permission.VIBRATE" />
</manifest>
